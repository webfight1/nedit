{
  "name": "nailedit",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/tailwind.build.css --watch\" \"sass --watch assets/scss/theme.scss:assets/css/theme.css\"",
    "build": "npx tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/tailwind.build.css --minify && sass assets/scss/theme.scss:assets/css/theme.css --style=compressed",
    "deploy": "scp -P 1022 -r /Applications/MAMP/htdocs/naileditwp/wp-content/themes/nailedit/ nailedit@nailedit.ee:/home/nailedit/www/wp-content/themes/nailedit",
    "deploy:build": "npm run build && npm run deploy",
    "watch-deploy": "chokidar \"**/*.{php,css,js,json,scss}\" -i \"node_modules/**\" -i \".git/**\" -i \".vscode/**\" -i \".idea/**\" -c \"npm run deploy\"",
    "watch-upload": "node watch-upload.js",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.6",
    "sass": "^1.94.2",
    "tailwindcss": "^3.4.14"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "node-ssh": "^13.2.1",
    "scp2": "^0.5.0"
  }
}
