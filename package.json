{
  "name": "nailedit",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npx tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/tailwind.build.css --watch\" \"sass --watch assets/scss/theme.scss:assets/css/theme.css\"",
    "build": "npx tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/tailwind.build.css --minify && sass assets/scss/theme.scss:assets/css/theme.css --style=compressed",
    "deploy": "rsync -avz --delete --exclude .git/ --exclude .idea/ --exclude .vscode/ --exclude node_modules/ --exclude .DS_Store --exclude *.log --exclude deploy.sh --exclude watch-deploy.sh /Applications/MAMP/htdocs/naileditwp/wp-content/themes/nailedit/ root@45.93.139.96:/var/www/html/nailedit/wp-content/themes/nailedit",
    "deploy:build": "npm run build && npm run deploy",
    "watch-deploy": "chokidar \"**/*.{php,css,js,json,scss}\" -i \"node_modules/**\" -i \".git/**\" -i \".vscode/**\" -i \".idea/**\" -c \"npm run deploy\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "sass": "^1.94.2",
    "tailwindcss": "^3.4.14"
  }
}
